":1610245791696,"results":"24","hashOfConfig":"14"},{"size":1114,"mtime":1610324192876,"results":"25","hashOfConfig":"14"},{"filePath":"26","messages":"27","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"28","usedDeprecatedRules":"29"},"kjhe6r",{"filePath":"30","messages":"31","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"29"},{"filePath":"32","messages":"33","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"29"},{"filePath":"34","messages":"35","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"36","usedDeprecatedRules":"29"},{"filePath":"37","messages":"38","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"39","usedDeprecatedRules":"29"},{"filePath":"40","messages":"41","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"42","usedDeprecatedRules":"29"},{"filePath":"43","messages":"44","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"45","usedDeprecatedRules":"29"},{"filePath":"46","messages":"47","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"48","usedDeprecatedRules":"29"},{"filePath":"49","messages":"50","errorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":"51","usedDeprecatedRules":"29"},{"filePath":"52","messages":"53","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"54","usedDeprecatedRules":"29"},{"filePath":"55","messages":"56","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"57","usedDeprecatedRules":"58"},{"filePath":"59","messages":"60","errorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"61","usedDeprecatedRules":"29"},"C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\index.js",["62"],"import React, { Component } from 'react';\nimport ReactDOM from 'react-dom';\nimport './index.css';\nimport App from './App';\n// import About from './components/About'\n// import Experience from './components/Experience'\n// import Publications from './components/Publications'\n// import Projects from './components/Projects'\n// import Press from './components/Press'\n// import Contact from './components/Cv'\n\n\n// import { render } from 'react-snapshot';\n// import * as serviceWorker from './serviceWorker';\n\nimport reportWebVitals from './components/reportWebVitals';\n\nReactDOM.render(\n  <React.StrictMode>\n    <App />\n  </React.StrictMode>,\ndocument.getElementById('root')\n);\n\n// If you want to start measuring performance in your app, pass a function\n// to log results (for example: reportWebVitals(console.log))\n// or send to an analytics endpoint. Learn more: https://bit.ly/CRA-vitals\nreportWebVitals();\n",["63","64"],"C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\App.js",[],"C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\reportWebVitals.js",[],"C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\Experience.js",["65"],"import React, { Component } from 'react';\nimport { FontAwesomeIcon } from '@fortawesome/react-fontawesome';\nimport { Container, Row, Col } from 'react-bootstrap';\nimport { Element } from 'react-scroll'\n\nexport default class ExperienceComponent extends Component {\n  render() {\n    return (\n    <React.Fragment>\n      <Element id='experienceComponent'>\n        <div style={{paddingTop: '75px'}}/>\n        <Container id='blackbox'>\n            <Row id='divbox' className='justify-content-md-center' style={{color: 'rgb(39, 137, 207)'}}><strong>RESEARCH EXPERIENCE</strong></Row>\n            <Row>\n              <Col md={12} style={{\n                color: '#DDDDDD',\n                fontSize: '16pt',\n              }}><strong>Current Positions</strong></Col>\n            </Row>\n            <Row>\n            <Col md={10} style={{\n                padding: '1.5em',\n                color: '#DDDDDD',\n                display: 'block'\n              }}>Moral Attitudes and Decision-Making (MAD) Lab @ Duke University\n            (Durham, NC)\n              <br/>PI: Drs. Walter Sinnott-Armstrong & Jana Schaich Borg<br/>Fall 2020-\n            </Col>\n            <Col md={2} style={{textAlign:'center'}}>\n              <div className='researchlabel'>\n                <br/><img src='x-phi.svg' className='researchicon' alt='experimental_philosophy'/>\n                <div style={{width: '120px', marginTop: '90px', marginLeft: '20px'}}><p style={{color: 'white'}}>Experimental Philosophy</p></div>\n              </div>\n            </Col>\n          </Row>\n          <Row>\n            <Col md={10} style={{\n                color: '#DDDDDD',\n                padding: '1.5em',\n              }}>Imagination and Modal Cognition (IMC) Lab @ Duke University\n              (Durham, NC)<br/>PI: Dr. Felipe De Brigard<br/>Fall 2019-\n            </Col>\n            <Col md={1} style={{textAlign:'right'}}>\n              <div className='researchlabel'>\n                <br/><img src='x-phi.svg' className='researchicon' alt='experimental_philosophy'/>\n                <div style={{width: '120px', marginTop: '90px', marginLeft: '-20px'}}><p style={{color: 'white'}}>Experimental Philosophy</p></div>\n              </div>\n            </Col>\n            <Col md={1} style={{textAlign:'left'}}>\n              <div className='researchlabel'>\n                <br/><img src='cog-neuro.svg' className='researchicon' alt='cognitive_neuroscience'/>\n                <div style={{width: '115px', marginTop: '90px', marginLeft: '-35px'}}><p style={{color: 'white'}}>Cognitive Neuroscience</p></div>\n              </div>\n            </Col>\n          </Row>\n          <Row>\n            <Col md={10} style={{\n                color: '#DDDDDD',\n                padding: '1.5em'\n              }}>\n              The Mind at Large Lab @ Duke University (Durham, NC)\n              <br/>PI: Dr. Paul Seli<br/>Fall 2019-\n            </Col>\n            <Col md={2} style={{textAlign:'center'}}>\n              <br/>\n                <div class='researchlabel'>\n                  <img src='cog-psych.svg' className='researchicon' alt='cognitive_psychology'/>\n                  <div style={{width: '105px', marginLeft: '22.5%'}}><p style={{color: 'white'}}>Cognitive Psychology</p></div>\n                </div>\n            </Col>\n          </Row>\n          <Row><Col md={12} style={{\n              color: '#999999',\n              fontSize: '16pt',\n            }}><strong>Past Positions</strong></Col></Row>\n          <Row>\n            <Col md={10} style={{\n                color: '#999999',\n                padding: '1.5em'\n              }}>\n              Morality Lab @ Boston College (Chestnut Hill, MA)\n              <br/>PIs: Drs. Liane Young & Gordon Kraft-Todd<br/>Summer 2020\n              <ul>\n                <li>2020 Remote Summer Internship</li>\n              </ul>\n            </Col>\n            <Col md={2} style={{textAlign:'center'}}>\n              <br/>\n              <div class='researchlabel'>\n                <img src='pers-soc-psych.svg' className='researchicon' alt='personality_social_psychology'/>\n                <div style={{width: '150px'}}><p style={{color: 'white'}}>Personality & Social Psychology</p></div>\n              </div>\n            </Col>\n          </Row>\n          <Row>\n            <Col md={10} style={{\n                color: '#999999',\n                padding: '1.5em'\n              }}>\n              Mind and Development (MaD) Lab @ Yale University (New Haven, CT)\n              <br/>PI: Dr. Paul Bloom<br/>Summer 2020\n              <ul>\n                <li>2020 Remote Summer Internship</li>\n              </ul>\n            </Col>\n            <Col md={1} style={{textAlign:'right'}}>\n              <div className='researchlabel'>\n                <br/><img src='dev-psych.svg' className='researchicon' alt='developmental_psychology'/>\n                <div style={{width: '135px', marginTop: '90px', marginLeft: '-20px'}}><p style={{color: 'white'}}>Developmental Psychology</p></div>\n              </div>\n            </Col>\n            <Col md={1} style={{textAlign:'left'}}>\n              <div className='researchlabel'>\n                <br/><img src='pers-soc-psych.svg' className='researchicon' alt='personality_social_psychology'/>\n                <div style={{width: '150px', marginTop: '90px', marginLeft: '-35px'}}><p style={{color: 'white'}}>Personality & Social Psychology</p></div>\n              </div>\n            </Col>\n          </Row>\n          <Row>\n            <Col md={10} style={{\n                color: '#999999',\n                padding: '1.5em'\n              }}>\n              Vision Sciences Group @ Johns Hopkins University (Baltimore, MD)\n              <br/> PIs: Drs. Jonathan Flombaum, Justin Halberda, & Chaz Firestone<br/>\n              Summer 2019\n              <ul>\n                <li>2019 Mind and Vision Summer Research Internship</li>\n              </ul>\n            </Col>\n            <Col md={2} style={{textAlign:'center'}}>\n              <br/>\n                <div class='researchlabel'>\n                  <img src='cog-psych.svg' className='researchicon' alt='cognitive_psychology'/>\n                  <div style={{width: '105px', marginLeft: '22.5%'}}><p style={{color: 'white'}}>Cognitive Psychology</p></div>\n                </div>\n            </Col>\n          </Row>\n          <Row>\n            <Col md={10} style={{\n                color: '#999999',\n                padding: '1.5em'\n              }}>\n              Behavioral Research Informing Teaching Excellence (BRITE) Lab @\n              Duke University (Durham, NC)\n              <br/>PI: Dr. Bridgette M. Hard<br/>Spring 2018-Fall 2020\n            </Col>\n            <Col md={2} style={{textAlign:'center'}}>\n              <br/>\n              <div class='researchlabel'>\n                <img src='pers-soc-psych.svg' className='researchicon' alt='personality_social_psychology'/>\n                <div style={{width: '150px'}}><p style={{color: 'white'}}>Personality & Social Psychology</p></div>\n              </div>\n            </Col>\n          </Row>\n          <Row>\n            <Col md={10} style={{\n                color: '#999999',\n                padding: '1.5em'\n              }}>\n              Department of Psychology @\n              Marist College (Poughkeepsie, NY)\n              <br/>PI: Dr. C Ryan Kinlaw<br/>Fall 2014-Spring 2017\n            </Col>\n            <Col md={2} style={{textAlign:'center'}}>\n              <br/>\n              <div class='researchlabel'>\n                <img src='pers-soc-psych.svg' className='researchicon' alt='personality_social_psychology'/>\n                <div style={{width: '150px'}}><p style={{color: 'white'}}>Personality & Social Psychology</p></div>\n              </div>\n            </Col>\n          </Row>\n        </Container>\n      </Element>\n    </React.Fragment>\n    )\n  }\n}\n","C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\Bio.js",["66"],"import React, { Component } from 'react';\nimport { FontAwesomeIcon } from '@fortawesome/react-fontawesome';\nimport { Container, Row, Col } from 'react-bootstrap';\n\nexport default class BioComponent extends Component {\n  render() {\n    return (\n    <div>\n      <Container style ={{\n          color: 'white',\n          paddingBottom: '25px',\n          paddingTop: '10px'\n        }}>\n        <div style ={{\n            paddingBottom: '15px'}}>\n          <a href='https://github.com/1nathanliang' className='socmed' id='github'><FontAwesomeIcon icon={['fab', 'github']} /></a>\n          <a href='https://scholar.google.com/citations?hl=en&user=ArVElRwAAAAJ' className='socmed' id='gscholar'><i style={{fontSize: '16pt'}} className='ai ai-google-scholar' /></a>\n          <a href='https://orcid.org/0000-0002-5308-6368' className='socmed' id='orcid'><FontAwesomeIcon icon={['fab', 'orcid']} /></a>\n          <a href='https://www.researchgate.net/profile/Nathan_Liang3' className='socmed' id='researchgate'><FontAwesomeIcon icon={['fab', 'researchgate']} /></a>\n          <a href='https://www.linkedin.com/in/1nathanliang/' className='socmed' id='linkedin'><FontAwesomeIcon icon={['fab', 'linkedin']} /></a>\n          <a href='https://twitter.com/1nathan_liang' className='socmed' id='twitter'><FontAwesomeIcon icon={['fab', 'twitter']} /></a>\n          <a href='https://academictree.org/psych/tree.php?pid=807836' className='socmed' id='psychtree'><FontAwesomeIcon icon='sitemap' /></a>\n          <a href='https://philpeople.org/profiles/nathan-liang' className='socmed' id='philpeople'><i style={{fontSize: '16pt'}} className='ai ai-philpapers'/></a>\n          <a href='https://papers.ssrn.com/sol3/cf_dev/AbsByAuth.cfm?per_id=3530786' className='socmed' id='ssrn'><i style={{fontSize: '18pt'}} className='ai ai-ssrn'/></a>\n          <a href='https://osf.io/zs8c7/' id='osf'><i style={{fontSize: '18pt'}} className='socmed' id='ai ai-osf'></i></a>\n          <a href='https://duke.academia.edu/1nathan_liang' className='socmed' id='academia'><i style={{fontSize: '16pt'}} className='ai ai-academia'/></a>\n          <a href='https://https://soundcloud.com/nate-l-446358831' className='socmed' id='soundcloud'><FontAwesomeIcon icon={['fab', 'soundcloud']} /></a>\n          <a href='https://open.spotify.com/playlist/34oXMyzX6Mq08Ujqb4aNNI?si=8381ok0zS_yGnLacR7gRzQ' className='socmed' id='spotify'><FontAwesomeIcon icon={['fab', 'spotify']} /></a>\n          <a href='https://www.yelp.com/user_details?userid=ui0yDO5xSB-MQ852yFFr9A' className='socmed' id='yelp'><FontAwesomeIcon icon={['fab', 'yelp']} /></a>\n      </div>\n        <Row id=\"intro\">\n            What's up! I'm a research assistant in the <strong><a href='https://kenan.ethics.duke.edu/mad-lab/'\n            class='redlink'>\n               Moral Attitudes and Decision-Making Lab</a></strong>\n             <br/>\n            with Dr. Walter Sinnott-Armstrong, the <strong><a href='https://www.imclab.org/' class='greenlink'>Imagination and Modal Cognition Lab</a></strong>\n            <br/>\n            with Dr. Felipe de Brigard, and the <strong><a href='https://www.mindatlargelab.com/' class='bluelink'>Mind at Large Lab</a></strong> with Dr. Paul Seli.\n        </Row>\n      </Container>\n      </div>\n    )\n  }\n}\n","C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\About.js",["67","68"],"import React, { Component } from 'react';\nimport { FontAwesomeIcon } from '@fortawesome/react-fontawesome';\nimport { Container, Row, Col } from 'react-bootstrap';\nimport { Element } from 'react-scroll'\n\nexport default class AboutComponent extends Component {\n  render() {\n    return (\n      <React.Fragment>\n        <Element id='aboutComponent'>\n          <Container>\n            <Row className='justify-content-md-center' style={{paddingBottom: '35px'}}>\n                <span className='circledec'></span>\n                <span className='circledec'></span>\n                <span className='circledec'></span>\n            </Row>\n          </Container>\n          <Container id='blackbox'>\n            <Row id='divbox' className=\"justify-content-md-center\" style={{color: 'rgb(19, 194, 75)'}}>\n              <strong>ABOUT</strong>\n            </Row>\n            <Row>\n              <div style={{\n                  color: '#DDDDDD',\n                  padding: '1.5em',\n                }}>\n                I'm a recent graduate of Duke University, where I studied\n                psychology, neuroscience, linguistics, evolutionary anthropology,\n                and philosophy with some phenomenal faculty and incredible\n                research mentors. I am currently involved in research projects\n                at the intersection of psychology and experimental philosophy,\n                and I'm most interested in topics in moral psychology\n                and normative ethics: dehumanization, cooperation,\n                religiosity, causal reasoning, and empathy, to name a few. I am an\n                enthusiastic advocate of robust, inclusive, and open science\n                research practices, and I'm always looking for new opportunities\n                to learn and grow as a cognitive scientist.\n              </div>\n            </Row>\n            <Row>\n              <div style={{\n                  color: '#999999',\n                  padding: '1.5em'\n                }}>\n                I have experience in data science and have freelanced as a UI/UX as\n                and graphic design artist for a startup,\n                ZenFoci, that I co-founded\n                with a fellow Blue Devil. I continue to\n                foster my creative interests in painting, drawing and\n                illustration, as well as digital art. As you have probably surmised\n                from the design of my site, I'm particularly fond of dark palettes.\n                I've begun to dabble in music production as well, so hopefully this\n                section will grow to become more substantial in the coming years.\n              </div>\n            </Row>\n            <Row>\n              <div style={{\n                  color: '#666666',\n                  padding: '1.5em',\n                }}>\n                In my free time, more than anything, I enjoy playing soccer. I\n                relived my days as a high school varsity player\n                at Duke and Johns Hopkins, and hopefully will\n                continue to do so wherever\n                life takes me. When I'm not on the pitch,\n                you can expect to find me listening to punk rock or watching the\n                latest sci-fi film.\n              </div>\n            </Row>\n          </Container>\n        </Element>\n      </React.Fragment>\n    )\n  }\n}\n","C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\Navbar.js",["69","70"],"import React, { Component } from 'react';\r\nimport { FontAwesomeIcon } from '@fortawesome/react-fontawesome';\r\nimport { Navbar, Nav, NavDropdown } from 'react-bootstrap';\r\nimport { Link, animateScroll as scroll } from 'react-scroll';\r\n\r\nexport default class NavComponent extends Component {\r\n  scrollToTop = () => {\r\n      scroll.scrollToTop();\r\n  };\r\n  render() {\r\n    return (\r\n      <Navbar className='nav-custom fixed-top' expand='lg'>\r\n        <Navbar.Brand id='brand-custom'><img src='nathanlogo.svg'\r\n          style={{height: '25px', width:'25px'}}/></Navbar.Brand>\r\n        <Navbar.Toggle aria-controls='basic-navbar-nav' />\r\n        <Navbar.Collapse id='basic-navbar-nav'>\r\n          <Nav className='mr-auto'>\r\n            <Nav.Link>\r\n              <Link to='aboutComponent' spy={true} smooth={true} duration={1500} className='animiddle' id='about'>about</Link>\r\n            </Nav.Link>\r\n            <Nav.Link>\r\n              <Link to='experienceComponent' spy={true} smooth={true} duration={1500} className='animiddle' id='experience'>experience</Link>\r\n            </Nav.Link>\r\n            <Nav.Link>\r\n              <Link to='publicationsComponent' spy={true} smooth={true} duration={1500} className='animiddle' id='publications'>publications</Link>\r\n            </Nav.Link>\r\n            <Nav.Link>\r\n              <Link to='projectsComponent' spy={true} smooth={true} duration={1500} className='animiddle' id='projects'>projects</Link>\r\n            </Nav.Link>\r\n            <Nav.Link>\r\n              <Link to='pressComponent' spy={true} smooth={true} duration={1500} className='animiddle' id='press'>press</Link>\r\n            </Nav.Link>\r\n            <Nav.Link>\r\n              <Link to='contactComponent' spy={true} smooth={true} duration={1500} className='animiddle' id='contact'>contact + cv</Link>\r\n            </Nav.Link>\r\n          </Nav>\r\n          <Nav inline>\r\n            <Nav.Link href='https://github.com/1nathanliang/1nathanliang.github.io' target='_blank' id='pagetop'><FontAwesomeIcon icon='info-circle' /></Nav.Link>\r\n            <Nav.Link onClick={this.scrollToTop} id=\"pagetop\"><FontAwesomeIcon icon='arrow-alt-circle-up' /></Nav.Link>\r\n          </Nav>\r\n        </Navbar.Collapse>\r\n      </Navbar>\r\n    );\r\n  }\r\n}\r\n","C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\Publications.js",["71"],"import React, { Component } from 'react';\nimport { FontAwesomeIcon } from '@fortawesome/react-fontawesome';\nimport { Container, Row, Col } from 'react-bootstrap';\nimport { Element } from 'react-scroll'\n\nexport default class PublicationsComponent extends Component {\n  render() {\n    return (\n      <React.Fragment>\n        <Element id='publicationsComponent'>\n          <div style={{paddingTop: '75px'}}/>\n          <Container id='blackbox'>\n              <Row id='divbox' className=\"justify-content-md-center\" style={{color: 'rgb(86, 69, 214)'}}><strong>PUBLICATIONS</strong></Row>\n            <Row>\n              <Col md={12} style={{\n                color: '#DDDDDD',\n                fontSize: '16pt',\n                paddingBottom: '1em'}}>\n                <strong>In Prep</strong>\n              </Col>\n            </Row>\n            <Row>\n              <Col md={12} style={{\n                color: '#DDDDDD'}}>\n                <ol>\n                  <li>Gerdin, E., <strong>Liang, N. </strong>, & Kraft-Todd, G. (in prep). Dimensions of dehumanization: Integrating theoretical perspectives using exploratory factor analysis.</li>\n                </ol>\n              </Col>\n            </Row>\n            <Row>\n              <Col md={12} style={{\n                color: '#999999',\n                fontSize: '16pt',\n                paddingBottom: '1em'}}>\n                <strong>Under Review</strong>\n              </Col>\n            </Row>\n            <Row>\n              <Col md={12} style={{\n                color: '#DDDDDD'}}>\n                <ol>\n                  <li>Murray, S., <strong>Liang, N.</strong>, Brosowsky, N.P.,\n                      Schooler, J., & Seli, P. (2020, under review). What are the\n                      benefits of mind wandering to creativity?</li>\n                  <li>Sridhar, H.S., Kimble, A., King, M.M., Johnson, C.P., Shah, R.J.,\n                      Dietzel, J.M., Yoo, C.H., Moreno, M.P., Pant, P., Edwards, J.A.,\n                      Lester, R.L., Linares, A.R., Wong, K.E., Vandekerckhove, V., Suh,\n                      Y.J., Stout, C.D., Stanback, I.E., Staley, T.G., Srivatsa, S.V.,\n                      <strong> . . .</strong> Samanez-Larkin, G.R. (2019, under review).\n                      Lower sleep variability associated with higher academic performance\n                      across the semester in college students.</li>\n              </ol>\n              </Col>\n            </Row>\n            <Row>\n              <Col md={12} style={{\n                color: '#666666',\n                fontSize: '16pt',\n                paddingBottom: '1em'}}>\n                <strong>Forthcoming</strong>\n              </Col>\n            </Row>\n            <Row>\n              <Col md={12} style={{\n                color: '#DDDDDD'}}>\n                <ol>\n                  <li>Hard, B. M., <strong>Liang, N.</strong>, Wong, M., &  Flusberg, S. J. (2020, forthcoming). Metaphors we teach by: Uncovering the structure of metaphorical lay theories of teaching. <em>Metaphor and the Social World</em></li>\n              </ol>\n              </Col>\n            </Row>\n          </Container>\n        </Element>\n      </React.Fragment>\n    )\n  }\n}\n","C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\Projects.js",["72","73","74","75","76"],"import React, { Component } from 'react';\nimport { FontAwesomeIcon } from '@fortawesome/react-fontawesome';\nimport { Container, Row, Col } from 'react-bootstrap';\nimport { Element } from 'react-scroll'\n\nexport default class ProjectsComponent extends Component {\n  render() {\n    return (\n      <React.Fragment>\n        <Element id='projectsComponent'>\n          <div style={{paddingTop: '75px'}}/>\n          <Container id='blackbox'>\n              <Row id='divbox' className=\"justify-content-md-center\" style={{color: 'rgb(214, 24, 90)'}}><strong>PROJECTS</strong></Row>\n            <Row>\n              <Col md={12} style={{\n                color: '#DDDDDD'}}>\n                <a href='https://zenfoci.com/' target='_blank' className='regprojtext'>ZenFoci by Incusublime, Inc.</a>\n              </Col>\n            </Row>\n            <Row>\n              <Col md={12} style={{\n                color: '#DDDDDD'}}>\n                <a href='https://bassconnections.duke.edu/project-teams/wired-learning-supporting-thinking-skills-k-2-classroom-2018-2019' target='_blank' className='regprojtext'>\n                Bass Connections: Wired for Learning\n                </a>\n              </Col>\n            </Row>\n            <Row>\n              <Col md={12}>\n                <a href='https://bassconnections.duke.edu/project-teams/good-comes-bad-dreams-2020-2021' target='_blank' className='regprojtext'>\n                  Bass Connections: The Good that Comes from Bad Dreams</a>\n              </Col>\n            </Row>\n            <Row>\n              <Col md={12}>\n                <a href='https://www.dukechronicle.com/article/2017/12/ran-out-of-food-points-students-with-excess-explain-strategy' target='_blank' className='regprojtext'>\n                  <em>The Chronicle</em></a>\n              </Col>\n            </Row>\n          </Container>\n        </Element>\n      </React.Fragment>\n    )\n  }\n}\n","C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\Cv.js",["77"],"import React, { Component } from 'react';\r\nimport { Button } from 'react-bootstrap';\r\nimport { Element } from 'react-scroll'\r\n\r\nclass CvPage extends Component {\r\n    toggleCv = (parameter) => {\r\n        var cvpdf = document.getElementById('cvpdf');\r\n        var cvbutton = document.getElementById('cvbutton');\r\n        if (cvpdf.style.display === 'none') {\r\n            cvpdf.style.display = 'block';\r\n            cvbutton.innerHTML = 'Close Document';\r\n        } else {\r\n            cvpdf.style.display = 'none';\r\n            cvbutton.innerHTML = 'View/Download Updated CV';\r\n        }\r\n    }\r\n    render() {\r\n      return (\r\n        <React.Fragment>\r\n          <Element id='contactComponent'>\r\n            <Button variant='outline-light' onClick={this.toggleCv} id='cvbutton'\r\n              style={{fontFamily: 'Source Sans Pro'}}>\r\n              View/Download Updated CV</Button>\r\n            <div id='cvpdf'>\r\n              <object\r\n                data='https://1nathanliang.github.io/cv.html'\r\n                type='application/pdf'\r\n                width='500'\r\n                height='678'\r\n              >\r\n                <iframe\r\n                  src='https://1nathanliang.github.io/cv.html'\r\n                  width='500'\r\n                  height='678'\r\n                >\r\n                <p>This browser does not support PDF!</p>\r\n                </iframe>\r\n              </object>\r\n            </div>\r\n        </Element>\r\n      </React.Fragment>\r\n    )\r\n  }\r\n}\r\n\r\nexport default CvPage;\r\n","C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\Footer.js",["78"],"import React, { Component } from 'react';\r\nimport { FontAwesomeIcon } from '@fortawesome/react-fontawesome';\r\nimport { Navbar, Nav } from 'react-bootstrap';\r\n\r\nconst FooterPage = () => {\r\n  return (\r\n    <Navbar className='footer-custom justify-content-center' expand='lg' style={{paddingTop: '20px'}}>\r\n        <Nav>\r\n          <p><strong>Coded with <FontAwesomeIcon icon='heart' style={{\r\n            color:'#ff3377',\r\n            fontSize: '6pt'}}/> Powered by <FontAwesomeIcon icon={['fab', 'react']} style={{\r\n            color:'#61DBFB',\r\n            fontSize: '7pt'\r\n          }}/> + <FontAwesomeIcon icon={['fab', 'bootstrap']} style={{\r\n            color:'#563d7c',\r\n            fontSize:'7pt'\r\n          }}/> </strong>\r\n          <br />&copy; {new Date().getFullYear()} Nathan Liang. All rights reserved.\r\n          <br />Background images: Unsplash & Nathan Liang.\r\n          <br />Website designed and developed by Nathan Liang.</p>\r\n        </Nav>\r\n  </Navbar>\r\n  );\r\n}\r\n\r\nexport default FooterPage;\r\n",["79","80"],"C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\Press.js",["81","82","83"],"import React, { Component } from 'react';\nimport { FontAwesomeIcon } from '@fortawesome/react-fontawesome';\nimport { Container, Row, Col } from 'react-bootstrap';\nimport { Element } from 'react-scroll'\n\nexport default class PressComponent extends Component {\n  render() {\n    return (\n      <React.Fragment>\n        <Element id='pressComponent'>\n          <div style={{paddingTop: '75px'}}/>\n          <Container id='blackbox'>\n              <Row id='divbox' className=\"justify-content-md-center\" style={{color: 'rgb(250, 128, 27)'}}><strong>PRESS</strong></Row>\n            <Row>\n              <Col md={12}>\n              <a href=\"https://bassconnections.duke.edu/about/news/behind-stereotypes-magazine-covers-data-team-finds-surprises\" target='_blank' className