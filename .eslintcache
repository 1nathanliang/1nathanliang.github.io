                height='678'\r\n              >\r\n                <iframe\r\n                  src='https://1nathanliang.github.io/cv.html'\r\n                  width='500'\r\n                  height='678'\r\n                >\r\n                <p>This browser does not support PDF!</p>\r\n                </iframe>\r\n              </object>\r\n            </div>\r\n        </Element>\r\n      </React.Fragment>\r\n    )\r\n  }\r\n}\r\n\r\nexport default CvPage;\r\n","C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\Footer.js",[],["56","57"],"C:\\Users\\1nath\\Documents\\GitHub\\reactwebapp\\1nathanliang.github.io\\src\\components\\Press.js",[],{"ruleId":"58","replacedBy":"59"},{"ruleId":"60","replacedBy":"61"},{"ruleId":"62","severity":1,"message":"63","line":31,"column":17,"nodeType":"64","endLine":35,"endColumn":18},{"ruleId":"58","replacedBy":"65"},{"ruleId":"60","replacedBy":"66"},"no-native-reassign",["67"],"no-negated-in-lhs",["68"],"jsx-a11y/iframe-has-title","<iframe> elements must have a unique title property.","JSXOpeningElement",["67"],["68"],"no-global-assign","no-unsafe-negation"]